# ============================================
# Tech Forum - 环境变量配置
# 复制此文件为 .env 并填入你的配置
# ============================================

# --- 数据库 ---
MYSQL_USERNAME=root
MYSQL_PASSWORD=

# --- Redis ---
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# --- 密码加密盐 ---
PASSWORD_SALT=your-salt-here

# --- AI 模型 API Keys (智谱AI) ---
AI_ZHIPU_API_KEY=
AI_GLM_46V_API_KEY=
AI_GLM_45AIR_API_KEY=
AI_GLM_47_API_KEY=

# --- 微信支付 (可选) ---
WX_PAY_APP_ID=
WX_PAY_MERCHANT_ID=
WX_PAY_PRIVATE_KEY_PATH=
WX_PAY_MERCHANT_SERIAL=
WX_PAY_API_V3_KEY=
WX_PAY_NOTIFY_URL=
WX_REFUND_NOTIFY_URL=

# --- 邮件 (可选) ---
MAIL_USERNAME=
MAIL_PASSWORD=
ALARM_EMAIL=

# --- OSS 对象存储 (可选) ---
OSS_BUCKET_NAME=
PAICODING_OSS_AK=
PAICODING_OSS_SK=

# --- AI Agent 地址 (可选) ---
AI_SMART_URL=http://localhost:9527/
